# ============================================================
# PANTRYPAL BACKEND - ENVIRONMENT VARIABLES
# ============================================================

# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# Format: postgresql://username:password@host:port/database
# Example: postgresql://user:password@localhost:5432/pantrypal_db
DATABASE_URL=postgresql://username:password@localhost:5432/pantrypal_db

# CORS Configuration
# Set to your frontend URL in production
CORS_ORIGIN=*

# Email Configuration (for verification codes and password reset)
# TODO: Configure based on your email service
EMAIL_SERVICE=your-email-service
EMAIL_USER=your-email@example.com
EMAIL_PASSWORD=your-password

# JWT Configuration (optional, for future token-based auth)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
# 
# 1. Copy this file to .env in the same directory
# 2. Update DATABASE_URL with your PostgreSQL connection string
# 3. Ensure your PostgreSQL database has been initialized with schema.sql
# 4. Run: npm install
# 5. Run: npm run dev (development) or npm start (production)
#
# ============================================================
